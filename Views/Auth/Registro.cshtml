@model Frontend_AprendeYa.Models.RegistroRequest
@{
    ViewData["Title"] = "Crear Cuenta";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AprendeYa</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

    <style>
            .login-background {
                background-image: url('/Img/FondoIngreo_Registro.png');
                background-size: cover;
                background-position: center;
                background-attachment: fixed;
                min-height: 100vh;
                width: 100%;
                display: flex;
                align-items: center;
                padding: 2rem 0;
            }

            .auth-card {
                border-radius: 20px;
                border: 1px solid rgba(255, 255, 255, 0.4);
                box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.3);
                background: rgba(255, 255, 255, 0.85);
                backdrop-filter: blur(12px);
                -webkit-backdrop-filter: blur(12px);
                overflow: hidden;
            }

            .auth-img-container {
                background-color: #f1ede5;
                text-align: center;
                padding: 0;
                border-bottom: 1px solid rgba(0, 0, 0, 0.05);
            }

            .auth-img {
                width: 100%;
                height: auto;
                display: block;
            }

            .input-group-text {
                background-color: rgba(255, 255, 255, 0.9);
                border-right: none;
                color: #7b8495;
            }

            .form-control-custom {
                border-left: none;
                background-color: rgba(255, 255, 255, 0.9);
                font-size: 0.9rem;
            }

            .form-control-custom:focus {
                box-shadow: none;
                border-color: #ced4da;
                background-color: #ffffff;
            }

            .input-group:focus-within {
                box-shadow: 0 0 0 0.2rem rgba(85, 110, 230, 0.25);
                border-radius: 0.375rem;
            }

            .btn-purple {
                background-color: #6152d9;
                color: white;
                border-radius: 10px;
                font-weight: 600;
                padding: 12px;
                transition: all 0.3s ease;
                border: none;
            }

            .btn-purple:hover {
                background-color: #4b3eb0;
                color: white;
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(97, 82, 217, 0.4);
            }

            .text-purple {
                color: #6152d9;
                font-weight: bold;
            }
    </style>
</head>
<body>

    <div class="login-background">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-11 col-sm-10 col-md-8 col-lg-6 col-xl-5">
                    <div class="card auth-card">
                        
                        <div class="auth-img-container">
                            <img src="/Img/registrarbaner.png" class="auth-img" alt="Ilustración de Registro" />
                        </div>

                        <div class="card-body p-4 p-md-5 pt-4">
                            <div class="text-center mb-4">
                                <h3 class="fw-bold text-dark">Crear Cuenta</h3>
                                <p class="text-muted small">Únete a nuestra plataforma</p>
                            </div>

                            @if (ViewBag.Error != null)
                            {
                                <div class="alert alert-danger text-center small py-2 rounded-3" style="background-color: rgba(248, 215, 218, 0.9);">
                                    @ViewBag.Error
                                </div>
                            }

                            <form asp-action="Registro" method="post">
                                
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="input-group mb-3 shadow-sm rounded">
                                            <span class="input-group-text rounded-start"><i class="fas fa-user"></i></span>
                                            <input asp-for="Nombres" type="text" class="form-control form-control-custom rounded-end" placeholder="Nombres" required />
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="input-group mb-3 shadow-sm rounded">
                                            <span class="input-group-text rounded-start"><i class="fas fa-user"></i></span>
                                            <input asp-for="Apellidos" type="text" class="form-control form-control-custom rounded-end" placeholder="Apellidos" required />
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="input-group mb-3 shadow-sm rounded">
                                            <span class="input-group-text rounded-start"><i class="fas fa-envelope"></i></span>
                                            <input asp-for="Correo" type="email" class="form-control form-control-custom rounded-end" placeholder="Correo Electrónico" required />
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="input-group mb-3 shadow-sm rounded">
                                            <span class="input-group-text rounded-start"><i class="fas fa-phone"></i></span>
                                            <input asp-for="Telefono" type="tel" class="form-control form-control-custom rounded-end" placeholder="Teléfono" required />
                                        </div>
                                    </div>
                                </div>

                                <div class="input-group mb-3 shadow-sm rounded">
                                    <span class="input-group-text rounded-start"><i class="fas fa-at"></i></span>
                                    <input asp-for="Username" type="text" class="form-control form-control-custom rounded-end" placeholder="Nombre de Usuario (Login)" required />
                                </div>

                                <div class="input-group mb-4 shadow-sm rounded">
                                    <span class="input-group-text rounded-start"><i class="fas fa-lock"></i></span>
                                    <input asp-for="Password" type="password" class="form-control form-control-custom" id="passwordInput" placeholder="Contraseña" required />
                                    <button class="btn btn-outline-secondary border-start-0 text-muted" type="button" id="togglePassword" style="font-size: 0.85rem; border-color: #ced4da; background-color: rgba(255,255,255,0.9);">Mostrar</button>
                                </div>

                                <button type="submit" class="btn btn-purple w-100 mb-4 shadow-sm">Registrarse</button>

                                <div class="text-center" style="font-size: 0.9rem;">
                                    <span class="text-muted fw-semibold">¿Ya tienes cuenta?</span>
                                    <a asp-controller="Auth" asp-action="Login" class="text-decoration-none text-purple">Inicia Sesión</a>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
            document.getElementById('togglePassword').addEventListener('click', function () {
                const passwordInput = document.getElementById('passwordInput');
                if (passwordInput.type === 'password') {
                    passwordInput.type = 'text';
                    this.textContent = 'Ocultar';
                } else {
                    passwordInput.type = 'password';
                    this.textContent = 'Mostrar';
                }
            });
    </script>
</body>
</html>