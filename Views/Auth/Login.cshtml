@model Frontend_AprendeYa.Models.LoginRequest
@{
    ViewData["Title"] = "Iniciar Sesión";
    Layout = null; // Quita la barra superior clásica
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AprendeYa</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

    <style>
            /* 1. EL CONTENEDOR DEL FONDO */
            .login-background {
                background-image: url('/Img/FondoIngreo_Registro.png');
                background-size: cover;
                background-position: center;
                background-attachment: fixed;
                min-height: 100vh;
                width: 100%;
                display: flex;
                align-items: center;
            }

            /* BOTÓN FLOTANTE PARA VOLVER AL INDEX */
            .back-to-home {
                position: absolute;
                top: 1.5rem;
                left: 1.5rem;
                background: rgba(255, 255, 255, 0.85);
                backdrop-filter: blur(10px);
                color: #333;
                padding: 10px 20px;
                border-radius: 30px;
                text-decoration: none;
                font-weight: 700;
                box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
                transition: all 0.3s ease;
                z-index: 1000;
                display: flex;
                align-items: center;
                gap: 8px;
            }

                .back-to-home:hover {
                    background: #f45b7a;
                    color: white;
                    transform: translateY(-2px);
                }

            /* 2. LA TARJETA EFECTO CRISTAL */
            .auth-card {
                border-radius: 20px;
                border: 1px solid rgba(255, 255, 255, 0.4);
                box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.3);
                background: rgba(255, 255, 255, 0.85);
                backdrop-filter: blur(12px);
                -webkit-backdrop-filter: blur(12px);
                overflow: hidden;
            }

            /* Ajustes para la imagen superior */
            .auth-img-container {
                background-color: #f1ede5; /* El color beige de tu imagen */
                text-align: center;
                padding: 0;
                border-bottom: 1px solid rgba(0, 0, 0, 0.05);
            }

            .auth-img {
                width: 100%;
                height: auto;
                display: block;
            }

            /* Estilos para los inputs */
            .input-group-text {
                background-color: rgba(255, 255, 255, 0.9);
                border-right: none;
                color: #7b8495;
            }

            .form-control-custom {
                border-left: none;
                background-color: rgba(255, 255, 255, 0.9);
            }

                .form-control-custom:focus {
                    box-shadow: none;
                    border-color: #ced4da;
                    background-color: #ffffff;
                }

            .input-group:focus-within {
                box-shadow: 0 0 0 0.2rem rgba(244, 91, 122, 0.25);
                border-radius: 0.375rem;
            }

            /* Botón Rosa */
            .btn-pink {
                background-color: #f45b7a;
                color: white;
                border-radius: 10px;
                font-weight: 600;
                padding: 12px;
                transition: all 0.3s ease;
                border: none;
            }

                .btn-pink:hover {
                    background-color: #d94260;
                    color: white;
                    transform: translateY(-2px);
                    box-shadow: 0 5px 15px rgba(244, 91, 122, 0.4);
                }

            .text-pink {
                color: #f45b7a;
                font-weight: bold;
            }
    </style>
</head>
<body>

    <!-- EL BOTÓN PARA VOLVER AL INDEX -->
    <a asp-controller="Home" asp-action="Index" class="back-to-home">
        <i class="fas fa-arrow-left"></i> Volver a AprendeYa
    </a>

    <div class="login-background">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-11 col-sm-8 col-md-6 col-lg-4">
                    <div class="card auth-card">
                        
                        <div class="auth-img-container">
                            <img src="/Img/loginbaner.png" class="auth-img" alt="Ilustración de Login" />
                        </div>

                        <div class="card-body p-4 p-md-5 pt-4">
                            <div class="text-center mb-4">
                                <h3 class="fw-bold text-dark">Iniciar Sesión</h3>
                                <p class="text-muted small">Accede a tu cuenta</p>
                            </div>

                            <!-- MENSAJE DE ERROR (ROJO) -->
                            @if (ViewBag.Error != null)
                            {
                                <div class="alert alert-danger text-center small py-2 rounded-3" style="background-color: rgba(248, 215, 218, 0.9);">
                                    @ViewBag.Error
                                </div>
                            }

                            <!-- MENSAJE DE ÉXITO AL REGISTRARSE (VERDE) -->
                            @if (TempData["Exito"] != null)
                            {
                                <div class="alert alert-success text-center small py-2 rounded-3" style="background-color: rgba(209, 231, 221, 0.9);">
                                    <i class="fas fa-check-circle"></i> @TempData["Exito"]
                                </div>
                            }

                            <form asp-action="Login" method="post">
                                <div class="input-group mb-3 shadow-sm rounded">
                                    <span class="input-group-text rounded-start"><i class="fas fa-envelope"></i></span>
                                    <input asp-for="Username" type="text" class="form-control form-control-custom rounded-end" placeholder="Usuario o Correo" required />
                                </div>

                                <div class="input-group mb-2 shadow-sm rounded">
                                    <span class="input-group-text rounded-start"><i class="fas fa-lock"></i></span>
                                    <input asp-for="Password" type="password" class="form-control form-control-custom" id="passwordInput" placeholder="Contraseña" required />
                                    <button class="btn btn-outline-secondary border-start-0 text-muted" type="button" id="togglePassword" style="font-size: 0.85rem; border-color: #ced4da; background-color: rgba(255,255,255,0.9);">Mostrar</button>
                                </div>

                                <div class="text-end mb-4">
                                    <a href="#" class="text-decoration-none text-dark fw-semibold" style="font-size: 0.85rem;">¿Olvidaste tu contraseña?</a>
                                </div>

                                <button type="submit" class="btn btn-pink w-100 mb-4 shadow-sm">Entrar</button>

                                <div class="text-center" style="font-size: 0.9rem;">
                                    <span class="text-muted fw-semibold">¿No tienes cuenta?</span>
                                    <!-- ENLACE A LA VISTA DE REGISTRO -->
                                    <a asp-controller="Auth" asp-action="Registro" class="text-decoration-none text-pink">Regístrate</a>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
            document.getElementById('togglePassword').addEventListener('click', function () {
                const passwordInput = document.getElementById('passwordInput');
                if (passwordInput.type === 'password') {
                    passwordInput.type = 'text';
                    this.textContent = 'Ocultar';
                } else {
                    passwordInput.type = 'password';
                    this.textContent = 'Mostrar';
                }
            });
    </script>
</body>
</html>