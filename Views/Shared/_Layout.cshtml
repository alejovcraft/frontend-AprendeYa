@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AprendeYa</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Frontend_AprendeYa.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark bg-primary border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="fas fa-graduation-cap"></i> AprendeYa
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        
                        @* COMPROBAMOS SI EL USUARIO ESTÁ LOGUEADO *@
                        @if (HttpContextAccessor.HttpContext.Session.GetString("JWToken") != null)
                        {
                            var idRol = HttpContextAccessor.HttpContext.Session.GetInt32("IdRol");

                            // El Catálogo lo ven TODOS los roles
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="Curso" asp-action="Index">
                                    <i class="fas fa-store"></i> Catálogo
                                </a>
                            </li>

                            // MENU EXCLUSIVO: ADMINISTRADOR (Rol 1)
                            @if (idRol == 1)
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-warning fw-bold" asp-controller="Curso" asp-action="Mantenimiento">
                                        <i class="fas fa-tools"></i> Mantenimiento Cursos
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-white fw-bold" asp-controller="Usuario" asp-action="Index">
                                        <i class="fas fa-users-cog"></i> Gestión Usuarios
                                    </a>
                                </li>
                                <!-- AQUÍ ESTÁ EL NUEVO BOTÓN DE REPORTES DEL ADMIN -->
                                <li class="nav-item">
                                    <a class="nav-link text-success fw-bold" asp-controller="Venta" asp-action="ReporteVentas">
                                        <i class="fas fa-file-invoice-dollar"></i> Ingresos
                                    </a>
                                </li>
                            }
                            // MENU EXCLUSIVO: ALUMNO (Rol 2)
                            else if (idRol == 2)
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-info fw-bold" asp-controller="Alumno" asp-action="MisCursos">
                                        <i class="fas fa-book-open"></i> Mis Cursos
                                    </a>
                                </li>
                            }
                            // MENU EXCLUSIVO: PROFESOR (Rol 3)
                            else if (idRol == 3)
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-success fw-bold" asp-controller="Profesor" asp-action="MisClases">
                                        <i class="fas fa-chalkboard-teacher"></i> Panel Docente
                                    </a>
                                </li>
                            }
                        }
                    </ul>

                    @* SECCIÓN DE USUARIO (Derecha de la barra) *@
                    <ul class="navbar-nav">
                        @if (HttpContextAccessor.HttpContext.Session.GetString("JWToken") != null)
                        {
                            var nombre = HttpContextAccessor.HttpContext.Session.GetString("NombreUsuario");
                            var idRol = HttpContextAccessor.HttpContext.Session.GetInt32("IdRol");
                            var nombreRol = idRol == 1 ? "(Admin)" : (idRol == 2 ? "(Alumno)" : "(Profesor)");

                            // EL CARRITO DE COMPRAS (Solo visible para el Alumno - Rol 2)
                            @if (idRol == 2)
                            {
                                <li class="nav-item d-flex align-items-center me-3">
                                    <a class="nav-link text-warning" asp-controller="Carrito" asp-action="Index" title="Ir a mi carrito">
                                        <i class="fas fa-shopping-cart fa-lg"></i>
                                    </a>
                                </li>
                            }

                            <li class="nav-item d-flex align-items-center me-3">
                                <span class="text-white">
                                    <i class="fas fa-user-circle"></i> Hola, @nombre <small class="text-light">@nombreRol</small>
                                </span>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-outline-light btn-sm mt-1" asp-controller="Auth" asp-action="Logout">Salir</a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="Auth" asp-action="Login">Iniciar Sesión</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted bg-light">
        <div class="container">
            &copy; 2026 - AprendeYa - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacidad</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>