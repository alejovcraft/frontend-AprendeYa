@model Frontend_AprendeYa.Models.Curso

@{
    ViewData["Title"] = "Publicar Nuevo Curso";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow border-0">
                <div class="card-header bg-success text-white">
                    <h4 class="mb-0"><i class="fas fa-plus-circle"></i> Crear Nuevo Curso</h4>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Crear">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="row">
                            <div class="col-md-12 mb-3">
                                <label asp-for="Titulo" class="form-label fw-bold"></label>
                                <input asp-for="Titulo" class="form-control" placeholder="Ej: Master en C# y .NET 8" />
                                <span asp-validation-for="Titulo" class="text-danger"></span>
                            </div>

                            <div class="col-md-12 mb-3">
                                <label asp-for="Descripcion" class="form-label fw-bold"></label>
                                <textarea asp-for="Descripcion" class="form-control" rows="3" placeholder="Describe brevemente de qué trata el curso..."></textarea>
                                <span asp-validation-for="Descripcion" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="Precio" class="form-label fw-bold"></label>
                                <div class="input-group">
                                    <span class="input-group-text">S/</span>
                                    <input asp-for="Precio" class="form-control" type="number" step="0.01" />
                                </div>
                                <span asp-validation-for="Precio" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="ImagenUrl" class="form-label fw-bold">URL de la Imagen</label>
                                <input asp-for="ImagenUrl" class="form-control" placeholder="https://ejemplo.com/imagen.jpg" />
                                <span asp-validation-for="ImagenUrl" class="text-danger"></span>
                            </div>

                            <div class="col-md-4 mb-3">
                                <label asp-for="IdNivel" class="form-label fw-bold">ID Nivel</label>
                                <input asp-for="IdNivel" class="form-control" type="number" />
                            </div>

                            <div class="col-md-4 mb-3">
                                <label asp-for="IdCategoria" class="form-label fw-bold">ID Categoría</label>
                                <input asp-for="IdCategoria" class="form-control" type="number" />
                            </div>

                            <div class="col-md-4 mb-3">
                                <label asp-for="IdInstructor" class="form-label fw-bold">ID Instructor</label>
                                <input asp-for="IdInstructor" class="form-control" type="number" />
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="Estado" class="form-label fw-bold"></label>
                                <select asp-for="Estado" class="form-select">
                                    <option value="Activo">Activo</option>
                                    <option value="Inactivo">Inactivo</option>
                                </select>
                            </div>
                        </div>

                        <hr />
                        <div class="d-flex justify-content-between">
                            <a asp-action="Mantenimiento" class="btn btn-outline-secondary">
                                <i class="fas fa-arrow-left"></i> Volver a la lista
                            </a>
                            <button type="submit" class="btn btn-success px-5">
                                <i class="fas fa-save"></i> Guardar Curso
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}