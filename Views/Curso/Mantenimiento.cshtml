@model IEnumerable<Frontend_AprendeYa.Models.Curso>

@{
    ViewData["Title"] = "Gestión de Cursos - Administración";
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="text-primary"><i class="fas fa-tasks"></i> Panel de Mantenimiento</h1>
        <a asp-action="Crear" class="btn btn-success shadow-sm">
            <i class="fas fa-plus"></i> Publicar Nuevo Curso
        </a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>ID</th>
                            <th>Título</th>
                            <th>Precio</th>
                            <th>Nivel</th>
                            <th>Categoría</th>
                            <th>Estado</th>
                            <th class="text-center">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="fw-bold">@item.IdCurso</td>
                                <td>@item.Titulo</td>
                                <td>S/ @item.Precio</td>
                                <td><span class="badge bg-info text-dark">ID: @item.IdNivel</span></td>
                                <td><span class="badge bg-secondary">ID: @item.IdCategoria</span></td>
                                <td>
                                    @if (item.Estado == "Activo")
                                    {
                                        <span class="text-success"><i class="fas fa-check-circle"></i> @item.Estado</span>
                                    }
                                    else
                                    {
                                        <span class="text-danger"><i class="fas fa-times-circle"></i> @item.Estado</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <div class="btn-group" role="group">
                                        <a asp-action="Editar" asp-route-id="@item.IdCurso" class="btn btn-warning btn-sm" title="Editar">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <a asp-action="Detalle" asp-route-id="@item.IdCurso" class="btn btn-info btn-sm text-white" title="Detalles">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <a asp-action="Eliminar" asp-route-id="@item.IdCurso"
                                           class="btn btn-danger btn-sm"
                                           onclick="return confirm('¿Estás seguro de que deseas eliminar este curso?');"
                                           title="Eliminar">
                                            <i class="fas fa-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>