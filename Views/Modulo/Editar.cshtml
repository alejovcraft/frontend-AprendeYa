@model Frontend_AprendeYa.Models.Modulo

@{
    ViewData["Title"] = "Editar";
}

<h1>Editar</h1>

<h2>Editar Módulo</h2>
<form asp-action="Editar">
    <input type="hidden" asp-for="IdModulo" />
    <input type="hidden" asp-for="IdCurso" />

    <div class="mb-3">
        <label asp-for="Titulo" class="form-label">Título</label>
        <input asp-for="Titulo" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="Descripcion" class="form-label">Descripción</label>
        <textarea asp-for="Descripcion" class="form-control"></textarea>
    </div>
    <div class="mb-3">
        <label asp-for="Orden" class="form-label">Orden</label>
        <input asp-for="Orden" class="form-control" type="number" />
    </div>

    <button type="submit" class="btn btn-primary">Actualizar</button>
    <a asp-action="Index" asp-route-idCurso="@Model.IdCurso" class="btn btn-secondary">Cancelar</a>
</form>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
